# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Keeper wallet (Policy Executor key)
KEEPER_KEYPAIR_PATH=./keeper-keypair.json

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/openclaw
REDIS_URL=redis://localhost:6379

# Referral vault (holds 10% of trading fees, keeper distributes to referrers)
REFERRAL_VAULT_KEYPAIR_PATH=./referral-vault-keypair.json
# REFERRAL_VAULT_KEYPAIR_JSON=  # Alternative: inline JSON array of secret key bytes
REFERRAL_MIN_PAYOUT_LAMPORTS=10000000   # 0.01 SOL minimum payout
REFERRAL_MAX_PAYOUTS_PER_RUN=50

# Monitoring
LOG_LEVEL=info
