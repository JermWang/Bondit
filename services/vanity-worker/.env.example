# ── BondIt Vanity Worker ───────────────────────────────────────────────────
# Copy to .env for local dev. Set these in Render Dashboard for prod.

DATABASE_URL=postgresql://bondit_user:PASSWORD@HOST:5432/bondit
LAUNCH_FACTORY_PROGRAM_ID=
VANITY_SUFFIX=LoL
VANITY_BACKLOG_TARGET=100
VANITY_WORKERS=3
VANITY_CHECK_INTERVAL_MS=10000
