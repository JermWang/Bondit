{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "@bondit/sdk": ["../../sdk/src/index.ts"],
      "@bondit/sdk/*": ["../../sdk/src/*"]
    }
  },
  "include": ["src/**/*", "../../sdk/src/api.ts"],
  "exclude": ["node_modules", "dist"]
}
