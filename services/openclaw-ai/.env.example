# ── BondIt OpenClaw AI Advisory Service ────────────────────────────────
# Copy to .env for local dev. Set these in Render Dashboard for prod.

# Team-funded AI provider keys (at least one required for LLM responses)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Indexer API (for fetching live launch context)
INDEXER_API_URL=http://localhost:4000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server port
PORT=3002

# Credit tracking
AI_DAILY_TOKEN_BUDGET=500000

# Rate limiting
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=30

# Logging
LOG_LEVEL=info
