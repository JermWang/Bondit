# ── BondIt OpenClaw AI Advisory Service ────────────────────────────────
# Copy to .env for local dev. Set these in Render Dashboard for prod.

# Team-funded AI provider keys (at least one required for LLM responses)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Indexer API (for fetching live launch context)
INDEXER_API_URL=http://localhost:4000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server port
PORT=3002

# Credit tracking
AI_DAILY_TOKEN_BUDGET=500000

# Rate limiting
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=30

# ── Intelligence Skills (all optional — degrade gracefully) ──────────
# ChainAware: Fraud detection & rug-pull prediction
CHAINAWARE_API_KEY=

# Birdeye: Solana token analytics & real-time prices
BIRDEYE_API_KEY=

# BICScan: Address risk scoring (0-100). Free key: https://www.bicscan.io
BICSCAN_API_KEY=

# Dune Analytics: On-chain data queries. Free tier: 2,500 credits/mo
DUNE_API_KEY=

# X/Twitter Research: Sentiment monitoring (X API Bearer Token)
X_BEARER_TOKEN=

# Pyth Network: Real-time price feeds (free, no key needed)
# Automatically available via Hermes API

# Logging
LOG_LEVEL=info
