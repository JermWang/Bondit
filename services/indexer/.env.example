# ── BondIt Indexer ─────────────────────────────────────────────────────────
# Copy to .env for local dev. Set these in Render Dashboard for prod.

DATABASE_URL=postgresql://bondit_user:PASSWORD@HOST:5432/bondit
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
PORT=4000

# Optional
CORS_ALLOWED_ORIGINS=https://www.bondit.lol,https://bondit.lol
REDIS_URL=
LOG_LEVEL=info
DATABASE_SSL_MODE=require
