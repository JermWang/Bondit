# ── BondIt.lol Next.js App ─────────────────────────────────────────────────
# Copy to .env.local for local dev. Set these in Vercel Dashboard for prod.

# Public (exposed to browser)
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_INDEXER_API_URL=https://bondit-indexer.onrender.com
NEXT_PUBLIC_AI_API_URL=

# Server-side only
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
DATABASE_URL=postgresql://bondit_user:PASSWORD@HOST:5432/bondit
CRON_SECRET=your-cron-secret-here

# Referral payouts (not needed until live)
REFERRAL_VAULT_KEYPAIR_JSON=
REFERRAL_MIN_PAYOUT_LAMPORTS=
REFERRAL_MAX_PAYOUTS_PER_RUN=50

# Keeper (not needed unless standalone)
KEEPER_API_URL=
