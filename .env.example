# Solana RPC (used by app, indexer, keeper, cli)
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# Database (Supabase / Postgres connection string)
DATABASE_URL=

# Phantom Server SDK (CLI / agent launches)
PHANTOM_ORG_ID=
PHANTOM_APP_ID=
PHANTOM_API_KEY=

# Keeper wallet
KEEPER_KEYPAIR_PATH=

# Indexer API (used by CLI and app for vanity backlog + data)
INDEXER_API_URL=http://localhost:4000
NEXT_PUBLIC_INDEXER_API_URL=http://localhost:4000

# Vanity worker (Render background worker)
VANITY_SUFFIX=LoL
VANITY_BACKLOG_TARGET=100
VANITY_WORKERS=3
VANITY_CHECK_INTERVAL_MS=10000
LAUNCH_FACTORY_PROGRAM_ID=LFac1111111111111111111111111111111111111111

# AI provider (default: Anthropic Claude, fallback: OpenAI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
