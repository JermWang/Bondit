# Solana RPC (used by app, indexer, keeper, cli)
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# Database (Supabase / Postgres connection string)
DATABASE_URL=

# Phantom Server SDK (CLI / agent launches)
# Get credentials at: https://phantom.com/portal/
PHANTOM_ORG_ID=
PHANTOM_APP_ID=
PHANTOM_PRIVATE_KEY=
PHANTOM_WALLET_ID=

# Keeper wallet
KEEPER_KEYPAIR_PATH=

# Indexer API (used by CLI and app for vanity backlog + data)
INDEXER_API_URL=http://localhost:4000
NEXT_PUBLIC_INDEXER_API_URL=http://localhost:4000

# Vanity worker (Render background worker)
VANITY_SUFFIX=LoL
VANITY_BACKLOG_TARGET=100
VANITY_WORKERS=3
VANITY_CHECK_INTERVAL_MS=10000
LAUNCH_FACTORY_PROGRAM_ID=

# Cron authentication (shared secret for Vercel cron + cron-jobs.org)
CRON_SECRET=
# Referral vault keypair (JSON array of secret key bytes — for serverless payout)
REFERRAL_VAULT_KEYPAIR_JSON=
REFERRAL_MIN_PAYOUT_LAMPORTS=10000000
REFERRAL_MAX_PAYOUTS_PER_RUN=50

# Keeper API (for cron proxy to trigger keeper jobs)
KEEPER_API_URL=

# AI provider (default: Anthropic Claude, fallback: OpenAI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OpenClaw AI service
NEXT_PUBLIC_AI_API_URL=http://localhost:3002
AI_DAILY_TOKEN_BUDGET=500000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=30
