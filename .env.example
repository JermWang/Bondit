# Shared logging
LOG_LEVEL=info

# Frontend (app)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_INDEXER_API_URL=http://localhost:3001/api
NEXT_PUBLIC_AI_API_URL=http://localhost:3002/api

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Service ports
INDEXER_PORT=3001
AI_PORT=3002

# HTTP allowlist / throttling
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INDEXER_RATE_LIMIT_WINDOW_MS=60000
INDEXER_RATE_LIMIT_MAX_REQUESTS=120
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=30

# Database / Redis
DATABASE_URL=
DATABASE_SSL_MODE=disable
DATABASE_SSL_REJECT_UNAUTHORIZED=false
SUPABASE_DB_URL=
SUPABASE_DATABASE_URL=
POSTGRES_URL=
POSTGRES_DB=bondit
POSTGRES_USER=bondit
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_PORT=5432
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Keeper
KEEPER_KEYPAIR_PATH=

# CLI keypair fallback
BONDIT_KEYPAIR_PATH=
SOLANA_KEYPAIR_PATH=

# Phantom Server SDK (CLI / agent launches)
PHANTOM_ORG_ID=
PHANTOM_APP_ID=
PHANTOM_API_KEY=
PHANTOM_API_URL=
PHANTOM_WALLET_ID=

# AI provider / advisory service
OPENAI_API_KEY=
